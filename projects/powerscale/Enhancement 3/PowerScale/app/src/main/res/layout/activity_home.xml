<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="@color/powerscale_background">

    <!--
        App Title
        Displays the name of the application at the top of the screen.
    -->
    <TextView
        android:id="@+id/textHomeTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textStyle="bold"
        android:textAppearance="@style/TextAppearance.PowerScale.Header"
        android:textColor="@color/powerscale_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        Subtitle
        Provides guidance to the user by explaining the purpose
        of this screen and prompting the next action.
    -->
    <TextView
        android:id="@+id/textHomeSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/home_subtitle"
        android:textAppearance="@style/TextAppearance.PowerScale"
        android:textColor="@color/powerscale_on_surface"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/textHomeTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        Weight Log Button
        Navigates the user to the Weight Log screen where
        they can view and manage their weight entries.
    -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonWeightLog"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/button_weight_log"
        android:textAppearance="@style/TextAppearance.PowerScale"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/textHomeSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_max="320dp" />

    <!--
        Goal Weight Button
        Navigates the user to the Goal Weight screen where
        they can view and manage their goal weight.
    -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonGoalWeight"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/button_goal_weight"
        android:textAppearance="@style/TextAppearance.PowerScale"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/buttonWeightLog"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_max="320dp" />

    <!--
        Profile Button
        Navigates the user to the Profile
        screen where they can view profile-specific information.
    -->

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonProfile"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/button_profile"
        android:textAppearance="@style/TextAppearance.PowerScale"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/buttonGoalWeight"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_max="320dp" />

    <!--
        SMS Settings Button
        Navigates the user to the SMS Notifications settings
        screen where they can manage SMS permissions and alerts.
    -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonSmsSettings"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/button_sms_settings"
        android:textAppearance="@style/TextAppearance.PowerScale"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/buttonProfile"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_max="320dp" />

    <!--
        Log Out Button
        Navigates the user back to the log in page and
        logs them out of the application.
    -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonLogout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/logout"
        android:textAllCaps="false"
        android:textAppearance="@style/TextAppearance.PowerScale"
        app:layout_constraintTop_toBottomOf="@id/buttonSmsSettings"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_max="320dp" />

    <!--
        Decorative Image
        Displays an anime-inspired image which relates to
        the PowerScale theme and visual style.
    -->
    <ImageView
        android:id="@+id/imagePowerUp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="24dp"
        android:src="@drawable/power_up"
        android:adjustViewBounds="true"
        android:scaleType="centerInside"
        android:contentDescription="@null"
        app:layout_constraintTop_toBottomOf="@id/buttonLogout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_max="200dp"
        app:layout_constraintVertical_bias="1.0" />

</androidx.constraintlayout.widget.ConstraintLayout>
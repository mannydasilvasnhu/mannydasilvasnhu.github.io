<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="@color/powerscale_background">

    <!--
        Screen Title
        Displays the title of the Goal Weight screen.
    -->
    <TextView
        android:id="@+id/textGoalTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/goal_title"
        android:textStyle="bold"
        android:textAppearance="@style/TextAppearance.PowerScale.Header"
        android:textColor="@color/powerscale_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        Current Goal Display
        Shows the user's currently saved goal weight.
    -->
    <TextView
        android:id="@+id/textCurrentGoal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/current_goal_none"
        android:textAppearance="@style/TextAppearance.PowerScale"
        android:textColor="@color/powerscale_on_surface"
        android:layout_marginTop="16dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/textGoalTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        Goal Input Card
        Contains the input field and button for saving a new goal weight.
    -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardGoal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardUseCompatPadding="true"
        app:cardBackgroundColor="@color/powerscale_surface"
        app:strokeColor="@color/powerscale_outline"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/textCurrentGoal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp">

            <!--
                Goal Weight Input
                Allows the user to enter a numeric goal weight in pounds.
            -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilGoal"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editGoal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/goal_hint"
                    android:inputType="numberDecimal"
                    android:minHeight="48dp"
                    android:textAppearance="@style/TextAppearance.PowerScale"
                    android:textColor="@color/powerscale_on_surface"
                    android:textColorHint="@color/powerscale_hint" />
            </com.google.android.material.textfield.TextInputLayout>

            <!--
                Save Goal Button
                Saves the entered goal weight to the database.
            -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonSaveGoal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/save_goal"
                android:textAppearance="@style/TextAppearance.PowerScale"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/tilGoal"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintWidth_max="320dp" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!--
        Decorative Image
        Displays an anime-inspired image which relates to
        the PowerScale theme and visual style.
    -->
    <ImageView
        android:id="@+id/imagePowerUp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="24dp"
        android:src="@drawable/power_up"
        android:adjustViewBounds="true"
        android:scaleType="centerInside"
        android:contentDescription="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_max="200dp"
        app:layout_constraintVertical_bias="1.0" />


</androidx.constraintlayout.widget.ConstraintLayout>

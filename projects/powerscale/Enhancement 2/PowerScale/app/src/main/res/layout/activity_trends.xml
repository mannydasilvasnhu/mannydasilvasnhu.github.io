<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/trendsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@color/powerscale_background"
    tools:context=".ui.TrendsActivity">

    <!--
        Screen Title
        Displays the title of the Trends screen.
    -->
    <TextView
        android:id="@+id/textTrendsTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/trends_screen_title"
        android:textStyle="bold"
        android:textAppearance="@style/TextAppearance.PowerScale.Header"
        android:textSize="26sp"
        android:gravity="center"
        android:textColor="@color/powerscale_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        Trends Summary Card
        Displays the moving average and trend direction
        calculated from the user's logged weight entries.
    -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardTrendsSummary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardUseCompatPadding="true"
        app:cardBackgroundColor="@color/powerscale_surface"
        app:strokeColor="@color/powerscale_outline"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/textTrendsTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp">

            <!--
                Section Header
                Labels the card as the trend summary area.
            -->
            <TextView
                android:id="@+id/textTrendsHeader"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/trends_section_title"
                android:textAppearance="@style/TextAppearance.PowerScale"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/powerscale_on_surface"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!--
                Moving Average Label
                Identifies the 7-day moving average output.
            -->
            <TextView
                android:id="@+id/textMovingAverageLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/moving_average_label"
                android:textAppearance="@style/TextAppearance.PowerScale"
                android:textStyle="bold"
                android:textColor="@color/powerscale_on_surface"
                app:layout_constraintTop_toBottomOf="@id/textTrendsHeader"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!--
                Moving Average Value
                Displays the most recent calculated moving average.
            -->
            <TextView
                android:id="@+id/textMovingAverageValue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/trend_not_enough_data"
                android:textAppearance="@style/TextAppearance.PowerScale"
                android:textColor="@color/powerscale_on_surface_secondary"
                app:layout_constraintTop_toBottomOf="@id/textMovingAverageLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!--
                Trend Direction Label
                Identifies the trend direction output.
            -->
            <TextView
                android:id="@+id/textTrendDirectionLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/trend_direction_label"
                android:textAppearance="@style/TextAppearance.PowerScale"
                android:textStyle="bold"
                android:textColor="@color/powerscale_on_surface"
                app:layout_constraintTop_toBottomOf="@id/textMovingAverageValue"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!--
                Trend Direction Value
                Displays the latest trend classification.
            -->
            <TextView
                android:id="@+id/textTrendDirectionValue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/trend_not_enough_data"
                android:textAppearance="@style/TextAppearance.PowerScale"
                android:textColor="@color/powerscale_on_surface_secondary"
                app:layout_constraintTop_toBottomOf="@id/textTrendDirectionLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!--
        Help Text
        Provides a short explanation of what the trend values mean.
    -->
    <TextView
        android:id="@+id/textTrendHelp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="@string/trends_help_text"
        android:textAppearance="@style/TextAppearance.PowerScale"
        android:textColor="@color/powerscale_on_surface_secondary"
        app:layout_constraintTop_toBottomOf="@id/cardTrendsSummary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        Back Button
        Returns the user to the Weight Log screen.
    -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonBackToLog"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/back_to_log"
        android:textAppearance="@style/TextAppearance.PowerScale"
        app:layout_constraintTop_toBottomOf="@id/textTrendHelp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_max="320dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/loginRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    tools:context=".LoginActivity">

    <!--
        App Title
        Displays the name of the application at the top of the screen.
    -->
    <TextView
        android:id="@+id/textAppTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textAppearance="@style/TextAppearance.PowerScale.Header"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="@color/powerscale_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        Subtitle
        Provides a tagline that supports the app theme
        and introduces the purpose of the application.
    -->
    <TextView
        android:id="@+id/textSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/app_slogan"
        android:textColor="@color/powerscale_on_surface"
        android:textAppearance="@style/TextAppearance.PowerScale"
        android:textSize="16sp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/textAppTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        Username Input Field
        Allows the user to enter their username for login
        or account creation.
    -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilUsername"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:hintTextColor="@color/powerscale_hint"
        android:textColor="@color/powerscale_on_surface"
        app:layout_constraintTop_toBottomOf="@id/textSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_max="360dp">


    <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/username_hint"
            android:textAppearance="@style/TextAppearance.PowerScale"
            android:inputType="textPersonName"
            android:maxLines="1"
            android:minHeight="48dp"
            android:textColor="@color/powerscale_on_surface"
            android:textColorHint="@color/powerscale_hint" />
    </com.google.android.material.textfield.TextInputLayout>

    <!--
        Password Input Field
        Allows the user to enter a password.
    -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilPassword"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:hintTextColor="@color/powerscale_hint"
        android:textColor="@color/powerscale_on_surface"
        app:layout_constraintTop_toBottomOf="@id/tilUsername"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_max="360dp"
        app:passwordToggleEnabled="true">

    <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/password_hint"
            android:textAppearance="@style/TextAppearance.PowerScale"
            android:inputType="textPassword"
            android:maxLines="1"
            android:minHeight="48dp"
            android:textColor="@color/powerscale_on_surface"
            android:textColorHint="@color/powerscale_hint" />
    </com.google.android.material.textfield.TextInputLayout>

    <!--
        Login Button
        Submits the user’s login information and navigates
        to the Home screen.
    -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonLogin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/button_login"
        android:textAppearance="@style/TextAppearance.PowerScale"
        app:layout_constraintTop_toBottomOf="@id/tilPassword"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_max="320dp"
        />

    <!--
        Create Account Button
        Allows first-time users to create a new account.
        For Project Two, it navigates directly to the Home screen.
    -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonCreateAccount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/button_create_account"
        android:textAppearance="@style/TextAppearance.PowerScale"
        app:layout_constraintTop_toBottomOf="@id/buttonLogin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_max="320dp" />

    <!--
        Informational Hint Text
        Explains how the user’s login information is used
        within the application.
    -->
    <TextView
        android:id="@+id/textHint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/login_hint"
        android:textColor="@color/powerscale_on_surface"
        android:textAppearance="@style/TextAppearance.PowerScale"
        android:textSize="14sp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/buttonCreateAccount"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        Decorative Image
        Displays an anime-inspired image which relates to
        the PowerScale theme and visual style.
    -->
    <ImageView
        android:id="@+id/imagePowerUp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="24dp"
        android:src="@drawable/power_up"
        android:adjustViewBounds="true"
        android:scaleType="centerInside"
        android:contentDescription="@null"
        app:layout_constraintTop_toBottomOf="@id/textHint"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_max="200dp"
        app:layout_constraintVertical_bias="1.0"/>

</androidx.constraintlayout.widget.ConstraintLayout>
